{
  "Kafka": {
    "BootstrapServers": "YOUR_CLUSTER.westeurope.azure.confluent.cloud:9092",
    "ApiKey":           "YOUR_KAFKA_API_KEY",
    "ApiSecret":        "YOUR_KAFKA_API_SECRET",
    "MedicinalProductsTopic": "hci.medicinal-products.avro",
    "DrugAlertsTopic":        "hci.drug-alerts.avro",
    "PriceUpdatesTopic":      "hci.price-updates.avro",
    "ConsumerGroupId":        "hci-avro-consumer"
  },
  "SchemaRegistry": {
    "Url":            "https://YOUR_SR_ENDPOINT.westeurope.azure.confluent.cloud",
    "ApiKey":         "YOUR_SR_API_KEY",
    "ApiSecret":      "YOUR_SR_API_SECRET",
    "MaxCachedSchemas": 1000
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
